<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:AccountingApp.Views"
       x:Class="AccountingApp.AppShell"
       Shell.TabBarIsVisible="True">

    <TabBar>
        <ShellContent Title="首頁"
                      Icon="tab_home.png"
                      ContentTemplate="{DataTemplate views:HomePage}"
                      Route="HomePage" />
        <ShellContent Title="記錄"
                      Icon="tab_list.png"
                      ContentTemplate="{DataTemplate views:TransactionListPage}"
                      Route="TransactionListPage" />
        <ShellContent Title="統計"
                      Icon="tab_chart.png"
                      ContentTemplate="{DataTemplate views:StatisticsPage}"
                      Route="StatisticsPage" />
        <ShellContent Title="分類報告"
                      Icon="tab_chart.png"
                      ContentTemplate="{DataTemplate views:CategoryReportPage}"
                      Route="CategoryReportPage" />
        <ShellContent Title="資產趨勢"
                      Icon="tab_chart.png"
                      ContentTemplate="{DataTemplate views:AssetTrendPage}"
                      Route="AssetTrendPage" />
        <ShellContent Title="分類管理"
                      Icon="tab_list.png"
                      ContentTemplate="{DataTemplate views:CategoryListPage}"
                      Route="CategoryListPageTab" />
        <ShellContent Title="預算"
                      Icon="tab_budget.png"
                      Shell.NavBarIsVisible="False"
                      ContentTemplate="{DataTemplate views:BudgetPage}"
                      Route="BudgetPage" />
        <ShellContent Title="設定"
                      Icon="tab_settings.png"
                      ContentTemplate="{DataTemplate views:SettingsPage}"
                      Route="SettingsPage" />
    </TabBar>

</Shell>
