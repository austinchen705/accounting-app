<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccountingApp.Views.Controls.CalendarDatePicker"
             x:Name="CalendarDatePickerRoot">
    <VerticalStackLayout Spacing="8">
        <Frame Style="{StaticResource InputContainerStyle}"
               IsVisible="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=ShowTrigger}">
            <Button Text="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=DateDisplayText}"
                    Command="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=OpenCalendarCommand}"
                    HorizontalOptions="Fill"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
        </Frame>

        <Frame Style="{StaticResource CardFrameStyle}"
               Padding="12"
               Margin="0,0,0,0"
               IsVisible="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=IsCalendarVisible}">
            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="6" VerticalOptions="Center">
                    <Button Text="«"
                            Command="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=PreviousCalendarYearCommand}"
                            WidthRequest="36"
                            HeightRequest="36"
                            Padding="0"
                            FontSize="18"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
                    <Button Text="‹"
                            Command="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=PreviousCalendarMonthCommand}"
                            Grid.Column="1"
                            WidthRequest="36"
                            HeightRequest="36"
                            Padding="0"
                            FontSize="18"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
                    <Label Grid.Column="2"
                           Text="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=CalendarMonthText}"
                           Style="{StaticResource SectionTitleStyle}"
                           LineBreakMode="WordWrap"
                           MaxLines="2"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                    <Button Grid.Column="3"
                            Text="›"
                            Command="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=NextCalendarMonthCommand}"
                            WidthRequest="36"
                            HeightRequest="36"
                            Padding="0"
                            FontSize="18"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
                    <Button Grid.Column="4"
                            Text="»"
                            Command="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=NextCalendarYearCommand}"
                            WidthRequest="36"
                            HeightRequest="36"
                            Padding="0"
                            FontSize="18"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
                </Grid>

                <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="4">
                    <Label Text="日" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="1" Text="一" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="2" Text="二" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="3" Text="三" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="4" Text="四" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="5" Text="五" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="6" Text="六" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                </Grid>

                <CollectionView ItemsSource="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=CalendarDays}"
                                SelectionMode="None"
                                HeightRequest="288">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="7" HorizontalItemSpacing="4" VerticalItemSpacing="6" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="0"
                                   Margin="0"
                                   CornerRadius="18"
                                   HeightRequest="36"
                                   WidthRequest="36"
                                   BackgroundColor="{Binding BackgroundColor}"
                                   BorderColor="{Binding BorderColor}"
                                   HasShadow="False"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Button Text="{Binding Label}"
                                        Command="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=SelectCalendarDateCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="{Binding TextColor}"
                                        Padding="0" />
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="完成"
                        Command="{Binding Source={x:Reference CalendarDatePickerRoot}, Path=CloseCalendarCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentView>
