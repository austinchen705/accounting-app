<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AccountingApp.Views.Controls"
             x:Class="AccountingApp.Views.TransactionListPage"
             Title="收支記錄">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="新增" Command="{Binding AddCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*" Padding="16,16,16,8" RowSpacing="8">

        <Frame Grid.Row="0" Style="{StaticResource CardFrameStyle}" Padding="12,8">
            <VerticalStackLayout Spacing="8">
                <Label Text="日期篩選" Style="{StaticResource CaptionStyle}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <controls:CalendarDatePicker Date="{Binding FilterDate}" />
                    <Button Grid.Column="1"
                            Text="今天"
                            Command="{Binding ResetToTodayCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="13"
                            Padding="10,6"
                            HeightRequest="36" />
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <Frame Grid.Row="1" Style="{StaticResource CardFrameStyle}" Padding="12,10">
            <VerticalStackLayout Spacing="8">
                <Label Text="當日總覽" Style="{StaticResource CaptionStyle}" />
                <Grid ColumnDefinitions="*,*,*">
                    <Label Text="{Binding DailyIncome, StringFormat='收入 {0:N0}'}"
                           TextColor="{StaticResource Success}"
                           HorizontalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding DailyExpense, StringFormat='支出 {0:N0}'}"
                           TextColor="{StaticResource Danger}"
                           HorizontalOptions="Center" />
                    <Label Grid.Column="2"
                           Text="{Binding DailyBalance, StringFormat='結餘 {0:N0}'}"
                           HorizontalOptions="Center" />
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <Grid Grid.Row="2">
            <Frame Style="{StaticResource CardFrameStyle}"
                   IsVisible="{Binding HasTransactions, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="當日尚無記錄"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Style="{StaticResource CaptionStyle}" />
            </Frame>

            <ScrollView IsVisible="{Binding HasTransactions}">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Transactions}" Spacing="8">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource CardFrameStyle}" Padding="14,10" Margin="0">
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Note}" FontAttributes="Bold" FontSize="15" />
                                            <Label Text="{Binding Date, StringFormat='{0:yyyy/MM/dd}'}"
                                                   Style="{StaticResource CaptionStyle}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding Amount, StringFormat='{0:N0}'}"
                                               Style="{StaticResource ValueStyle}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="expense">
                                                    <Setter Property="TextColor" Value="{StaticResource Danger}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="income">
                                                    <Setter Property="TextColor" Value="{StaticResource Success}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>
                                    <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                        <Button Text="編輯"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                                CommandParameter="{Binding .}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                FontSize="13"
                                                Padding="10,6"
                                                HeightRequest="34" />
                                        <Button Text="刪除"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource Danger}"
                                                FontSize="13"
                                                Padding="10,6"
                                                HeightRequest="34" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>
</ContentPage>
