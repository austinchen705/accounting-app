<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AccountingApp.Views.Controls"
             xmlns:markup="clr-namespace:AccountingApp.Markup"
             x:Class="AccountingApp.Views.TransactionListPage"
             Title="{markup:Translate TransactionListPageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{markup:Translate TransactionListAddButton}" Command="{Binding AddCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*" Padding="16,16,16,8" RowSpacing="8">

        <Frame Grid.Row="0" Style="{StaticResource CardFrameStyle}" Padding="12,8">
            <VerticalStackLayout Spacing="8">
                <Label Text="{markup:Translate TransactionListDateFilterLabel}" Style="{StaticResource CaptionStyle}" />
                <VerticalStackLayout Spacing="8">
                    <controls:CalendarDatePicker Date="{Binding FilterDate}" />
                    <Button Text="{markup:Translate TransactionListTodayButton}"
                            Command="{Binding ResetToTodayCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="13"
                            Padding="10,6"
                            HeightRequest="36"
                            HorizontalOptions="End" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <Frame Grid.Row="1" Style="{StaticResource CardFrameStyle}" Padding="12,10">
            <VerticalStackLayout Spacing="8">
                <Label Text="{markup:Translate TransactionListDailySummaryTitle}" Style="{StaticResource CaptionStyle}" />
                <Label Text="{Binding SummaryCurrencyText}"
                       Style="{StaticResource CaptionStyle}"
                       HorizontalOptions="Center" />
                <Grid ColumnDefinitions="*,*,*">
                    <Label Text="{Binding DailyIncomeText}"
                           TextColor="{StaticResource Success}"
                           HorizontalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding DailyExpenseText}"
                           TextColor="{StaticResource Danger}"
                           HorizontalOptions="Center" />
                    <Label Grid.Column="2"
                           Text="{Binding DailyBalanceText}"
                           HorizontalOptions="Center" />
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <Grid Grid.Row="2">
            <Frame Style="{StaticResource CardFrameStyle}"
                   IsVisible="{Binding HasTransactions, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="{markup:Translate TransactionListEmptyStateText}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Style="{StaticResource CaptionStyle}" />
            </Frame>

            <ScrollView IsVisible="{Binding HasTransactions}">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Transactions}" Spacing="8">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource CardFrameStyle}" Padding="14,10" Margin="0">
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Date, StringFormat='{0:yyyy/MM/dd}'}"
                                                   Style="{StaticResource CaptionStyle}" />
                                            <Label Text="{Binding CategoryName}"
                                                   Style="{StaticResource CaptionStyle}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding CategoryName}" Value="">
                                                        <Setter Property="IsVisible" Value="False" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Label Text="{Binding Note}"
                                                   Style="{StaticResource CaptionStyle}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Note}" Value="">
                                                        <Setter Property="IsVisible" Value="False" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Label Text="{Binding ExchangeInfoText}"
                                                   Style="{StaticResource CaptionStyle}"
                                                   IsVisible="{Binding HasExchangeInfo}" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="4"
                                                             HorizontalOptions="End"
                                                             VerticalOptions="Center">
                                            <Label Text="📷"
                                                   FontSize="12"
                                                   HorizontalOptions="End"
                                                   Opacity="0.9"
                                                   IsVisible="{Binding HasAttachmentImage}" />
                                            <Label Text="{Binding AmountDisplayText}"
                                                   Style="{StaticResource ValueStyle}"
                                                   VerticalOptions="Center"
                                                   HorizontalTextAlignment="End">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="expense">
                                                        <Setter Property="TextColor" Value="{StaticResource Danger}" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="income">
                                                        <Setter Property="TextColor" Value="{StaticResource Success}" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </VerticalStackLayout>
                                    </Grid>
                                    <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                        <Button Text="{markup:Translate EditButtonText}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                                CommandParameter="{Binding .}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                FontSize="13"
                                                Padding="10,6"
                                                HeightRequest="34" />
                                        <Button Text="{markup:Translate DeleteButtonText}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource Danger}"
                                                FontSize="13"
                                                Padding="10,6"
                                                HeightRequest="34" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>
</ContentPage>
