<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccountingApp.Views.CategoryFormPage"
             Title="{Binding FormTitle}">
    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,24" Spacing="0">
            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding FormTitle}"
                           Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="建立新分類，或調整既有分類的名稱與類型。"
                           Style="{StaticResource CaptionStyle}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="分類名稱" Style="{StaticResource CaptionStyle}" />
                        <Frame Style="{StaticResource InputContainerStyle}">
                            <Entry Text="{Binding Name}"
                                   Placeholder="例如：咖啡、健身、房租" />
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="類型" Style="{StaticResource CaptionStyle}" />
                        <Frame Style="{StaticResource InputContainerStyle}">
                            <Picker Title="選擇類型"
                                    ItemsSource="{Binding TypeOptions}"
                                    SelectedItem="{Binding SelectedTypeOption}"
                                    ItemDisplayBinding="{Binding Label}" />
                        </Frame>
                    </VerticalStackLayout>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           IsVisible="{Binding HasError}" />

                    <Button Text="{Binding SubmitButtonText}"
                            Command="{Binding SaveCommand}" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
