<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccountingApp.Views.CategoryFormPage"
             Title="新增分類">
    <VerticalStackLayout Padding="16" Spacing="12">
        <Label Text="分類名稱" />
        <Entry Text="{Binding Name}" Placeholder="例如：咖啡、健身" />

        <Label Text="類型" />
        <Picker Title="選擇類型"
                ItemsSource="{Binding TypeOptions}"
                SelectedItem="{Binding SelectedTypeOption}"
                ItemDisplayBinding="{Binding Label}" />

        <Label Text="{Binding ErrorMessage}" TextColor="Red"
               IsVisible="{Binding HasError}" />

        <Button Text="儲存" Command="{Binding SaveCommand}" />
    </VerticalStackLayout>
</ContentPage>
