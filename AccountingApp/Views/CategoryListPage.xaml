<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:markup="clr-namespace:AccountingApp.Markup"
             x:Class="AccountingApp.Views.CategoryListPage"
             x:Name="CategoryListPageRoot"
             Title="{markup:Translate CategoryListPageTitle}">
    <ScrollView x:Name="CategoryScrollView">
        <VerticalStackLayout Padding="16,16,16,24" Spacing="0">
            <Frame x:Name="CategoryFormCard"
                   Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding FormTitleText}"
                           Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="{markup:Translate CategoryListDescription}"
                           Style="{StaticResource CaptionStyle}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="{markup:Translate CategoryNameLabel}" Style="{StaticResource CaptionStyle}" />
                        <Frame Style="{StaticResource InputContainerStyle}">
                            <Entry Text="{Binding Name}"
                                   Placeholder="{markup:Translate CategoryNamePlaceholder}" />
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="{markup:Translate CategoryTypeLabel}" Style="{StaticResource CaptionStyle}" />
                        <Frame Style="{StaticResource InputContainerStyle}">
                            <Picker Title="{markup:Translate CategoryTypePickerTitle}"
                                    ItemsSource="{Binding TypeOptions}"
                                    SelectedItem="{Binding SelectedTypeOption}"
                                    ItemDisplayBinding="{Binding Label}" />
                        </Frame>
                    </VerticalStackLayout>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           IsVisible="{Binding HasError}" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button Text="{Binding SubmitButtonText}"
                                Grid.Column="0"
                                Command="{Binding SaveCommand}" />
                        <Button Text="{markup:Translate CategoryCancelEditButton}"
                                Grid.Column="1"
                                Command="{Binding CancelEditCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                IsVisible="{Binding IsEditing}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Label Text="{markup:Translate CategoryListEmptyStateText}"
                   Style="{StaticResource CaptionStyle}"
                   HorizontalOptions="Center"
                   Margin="0,12,0,0"
                   IsVisible="{Binding HasCategories, Converter={StaticResource InverseBoolConverter}}" />

            <CollectionView ItemsSource="{Binding Categories}"
                            SelectionMode="None"
                            IsVisible="{Binding HasCategories}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource CardFrameStyle}"
                               Padding="14,12">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               FontSize="17" />
                                        <Label Text="{Binding TypeText}"
                                               Style="{StaticResource CaptionStyle}" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1"
                                            Padding="10,4"
                                            BackgroundColor="{StaticResource Secondary}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="999" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding TypeText}"
                                               FontSize="12"
                                               TextColor="{StaticResource Primary}"
                                               VerticalTextAlignment="Center" />
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10">
                                    <Button Text="{markup:Translate EditButtonText}"
                                            Grid.Column="0"
                                            Command="{Binding Source={x:Reference CategoryListPageRoot}, Path=BindingContext.EditCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Text="{markup:Translate DeleteButtonText}"
                                            Grid.Column="1"
                                            Command="{Binding Source={x:Reference CategoryListPageRoot}, Path=BindingContext.DeleteCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Danger}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
