<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             xmlns:markup="clr-namespace:AccountingApp.Markup"
             x:Class="AccountingApp.Views.StatisticsPage"
             Title="{markup:Translate StatisticsPageTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,24" Spacing="2">
            <Label Text="{markup:Translate StatisticsPageTitle}" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,8" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Button Text="‹" Command="{Binding PreviousMonthCommand}" WidthRequest="42" HeightRequest="42" Padding="0" />
                    <Label Grid.Column="1"
                           Text="{Binding SelectedMonth, StringFormat='{0:yyyy年MM月}'}"
                           Style="{StaticResource SectionTitleStyle}"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                    <Button Grid.Column="2" Text="›" Command="{Binding NextMonthCommand}" WidthRequest="42" HeightRequest="42" Padding="0" />
                </Grid>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{markup:Translate StatisticsPieSectionTitle}" Style="{StaticResource SectionTitleStyle}" />
                    <Grid ColumnDefinitions="1.35*,1*" ColumnSpacing="12" IsVisible="{Binding HasPieData}">
                        <lvc:PieChart Series="{Binding PieSeries}"
                                      InitialRotation="-90"
                                      MaxAngle="360"
                                      LegendPosition="Hidden"
                                      HeightRequest="230" />
                        <CollectionView Grid.Column="1"
                                        ItemsSource="{Binding PieLegends}"
                                        SelectionMode="None"
                                        VerticalOptions="Center">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="2,0">
                                        <BoxView WidthRequest="10"
                                                 HeightRequest="10"
                                                 CornerRadius="5"
                                                 Color="{Binding DotColor}"
                                                 VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Name}"
                                               Style="{StaticResource CaptionStyle}" />
                                        <Label Grid.Column="2"
                                               Text="{Binding PercentageText}"
                                               Style="{StaticResource CaptionStyle}"
                                               FontAttributes="Bold" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                    <Label Text="{markup:Translate StatisticsPieEmptyStateText}"
                           Style="{StaticResource CaptionStyle}"
                           HorizontalOptions="Center"
                           IsVisible="{Binding HasPieData, Converter={StaticResource InverseBoolConverter}}" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}" Margin="0,0,0,0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{markup:Translate StatisticsTrendSectionTitle}" Style="{StaticResource SectionTitleStyle}" />
                    <lvc:CartesianChart Series="{Binding TrendSeries}"
                                        XAxes="{Binding TrendXAxes}"
                                        YAxes="{Binding TrendYAxes}"
                                        LegendPosition="Bottom"
                                        HeightRequest="240"
                                        IsVisible="{Binding HasBarData}" />
                    <Label Text="{Binding BarChartUnitText}"
                           Style="{StaticResource CaptionStyle}"
                           HorizontalOptions="End"
                           IsVisible="{Binding HasBarData}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" IsVisible="{Binding HasBarData}">
                        <Frame Style="{StaticResource CardFrameStyle}" Padding="10,8" Margin="0">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{markup:Translate StatisticsIncomeMoMLabel}" Style="{StaticResource CaptionStyle}" />
                                <Label Text="{Binding IncomeMoMText}" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="1" Style="{StaticResource CardFrameStyle}" Padding="10,8" Margin="0">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{markup:Translate StatisticsExpenseMoMLabel}" Style="{StaticResource CaptionStyle}" />
                                <Label Text="{Binding ExpenseMoMText}" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                    <Label Text="{Binding MaxExpenseText}"
                           Style="{StaticResource CaptionStyle}"
                           IsVisible="{Binding HasBarData}" />
                    <Label Text="{Binding MinNetText}"
                           Style="{StaticResource CaptionStyle}"
                           IsVisible="{Binding HasBarData}" />
                    <Label Text="{markup:Translate StatisticsTrendEmptyStateText}"
                           Style="{StaticResource CaptionStyle}"
                           HorizontalOptions="Center"
                           IsVisible="{Binding HasBarData, Converter={StaticResource InverseBoolConverter}}" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}" Margin="0,0,0,0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{markup:Translate StatisticsCategoryTrendSectionTitle}" Style="{StaticResource SectionTitleStyle}" />
                    <lvc:CartesianChart Series="{Binding CategoryTrendSeries}"
                                        XAxes="{Binding CategoryTrendXAxes}"
                                        YAxes="{Binding CategoryTrendYAxes}"
                                        LegendPosition="Bottom"
                                        HeightRequest="260"
                                        IsVisible="{Binding HasCategoryTrendData}" />
                    <Label Text="{markup:Translate StatisticsCategoryTrendEmptyStateText}"
                           Style="{StaticResource CaptionStyle}"
                           HorizontalOptions="Center"
                           IsVisible="{Binding HasCategoryTrendData, Converter={StaticResource InverseBoolConverter}}" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
