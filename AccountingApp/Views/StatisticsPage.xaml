<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="AccountingApp.Views.StatisticsPage"
             Title="統計">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- 月份切換 -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">
                <Button Text="&lt;" Command="{Binding PreviousMonthCommand}" WidthRequest="44" />
                <Label Text="{Binding SelectedMonth, StringFormat='{0:yyyy年MM月}'}"
                       FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                <Button Text="&gt;" Command="{Binding NextMonthCommand}" WidthRequest="44" />
            </HorizontalStackLayout>

            <!-- 圓餅圖 -->
            <Label Text="各分類支出佔比" FontSize="16" FontAttributes="Bold" />
            <microcharts:ChartView Chart="{Binding PieChart}"
                                   HeightRequest="250"
                                   IsVisible="{Binding HasPieData}" />
            <Label Text="本月尚無支出記錄" TextColor="Gray" HorizontalOptions="Center"
                   IsVisible="{Binding HasPieData, Converter={StaticResource InverseBoolConverter}}" />

            <!-- 長條圖 -->
            <Label Text="近 6 個月收支趨勢" FontSize="16" FontAttributes="Bold" />
            <microcharts:ChartView Chart="{Binding BarChart}"
                                   HeightRequest="220"
                                   IsVisible="{Binding HasBarData}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
