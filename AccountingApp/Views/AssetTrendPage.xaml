<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AccountingApp.Views.Controls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             xmlns:markup="clr-namespace:AccountingApp.Markup"
             x:Class="AccountingApp.Views.AssetTrendPage"
             Title="{markup:Translate AssetTrendPageTitle}">

    <ScrollView x:Name="PageScrollView">
        <VerticalStackLayout Padding="16,16,16,24" Spacing="12">
            <Label Text="{markup:Translate AssetTrendPageTitle}" Style="{StaticResource PageTitleStyle}" />

            <Frame x:Name="SnapshotFormFrame" Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding FormTitleText}" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="{Binding EditingSnapshotDisplayText}"
                           Style="{StaticResource CaptionStyle}"
                           TextColor="#1D4ED8"
                           IsVisible="{Binding IsEditing}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                        <Label Text="{markup:Translate AssetTrendStockLabel}" Style="{StaticResource CaptionStyle}" />
                        <Label Grid.Column="1" Text="{markup:Translate TransactionFormDateLabel}" Style="{StaticResource CaptionStyle}" />
                        <Frame Grid.Row="1" Style="{StaticResource InputContainerStyle}">
                            <Entry Text="{Binding Stock}"
                                   Keyboard="Numeric"
                                   Placeholder="0" />
                        </Frame>
                        <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource InputContainerStyle}">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8"
                                  Padding="12,10">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference SnapshotCalendarDatePicker}, Path=OpenCalendarCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="{Binding Source={x:Reference SnapshotCalendarDatePicker}, Path=DateDisplayText}"
                                       VerticalOptions="Center"
                                       FontSize="16"
                                       FontAttributes="None"
                                       LineBreakMode="NoWrap"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
                                <Label Grid.Column="1"
                                       Text="⌄"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       FontSize="16"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}" />
                            </Grid>
                        </Frame>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                        <Label Text="{markup:Translate AssetTrendCashLabel}" Style="{StaticResource CaptionStyle}" />
                        <Label Grid.Column="1" Text="{markup:Translate AssetTrendFirstTradeLabel}" Style="{StaticResource CaptionStyle}" />
                        <Frame Grid.Row="1" Style="{StaticResource InputContainerStyle}">
                            <Entry Text="{Binding Cash}"
                                   Keyboard="Numeric"
                                   Placeholder="0" />
                        </Frame>
                        <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource InputContainerStyle}">
                            <Entry Text="{Binding FirstTrade}"
                                   Keyboard="Numeric"
                                   Placeholder="0" />
                        </Frame>
                    </Grid>

                    <Label Text="{markup:Translate AssetTrendPropertyLabel}" Style="{StaticResource CaptionStyle}" />
                    <Frame Style="{StaticResource InputContainerStyle}">
                        <Entry Text="{Binding Property}"
                               Keyboard="Numeric"
                               Placeholder="0" />
                    </Frame>

                    <controls:CalendarDatePicker x:Name="SnapshotCalendarDatePicker"
                                                 Date="{Binding SnapshotDate}"
                                                 ShowTrigger="False" />

                    <Button Text="{markup:Translate AssetTrendImportCsvButton}" Command="{Binding ImportCsvCommand}" />
                    <Label Text="{Binding ImportSummaryText}"
                           Style="{StaticResource CaptionStyle}"
                           IsVisible="{Binding HasImportSummary}" />
                    <Label Text="{Binding ImportErrorDetailsText}"
                           Style="{StaticResource CaptionStyle}"
                           TextColor="#B45309"
                           IsVisible="{Binding HasImportErrorDetails}" />
                    <Button Text="{Binding SubmitButtonText}" Command="{Binding AddSnapshotCommand}" />
                    <Button Text="{markup:Translate AssetTrendCancelEditButton}"
                            Command="{Binding CancelEditCommand}"
                            IsVisible="{Binding IsEditing}" />
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#B91C1C"
                           IsVisible="{Binding HasError}" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{markup:Translate AssetTrendChartSectionTitle}" Style="{StaticResource SectionTitleStyle}" />
                    <VerticalStackLayout Spacing="2"
                                         IsVisible="{Binding HasSnapshots}">
                        <Label Text="{Binding LatestTotalCaptionText}"
                               Style="{StaticResource CaptionStyle}" />
                        <Label Text="{Binding LatestTotalAmountText}"
                               FontAttributes="Bold"
                               FontSize="22" />
                    </VerticalStackLayout>
                    <lvc:CartesianChart Series="{Binding TrendSeries}"
                                        XAxes="{Binding TrendXAxes}"
                                        YAxes="{Binding TrendYAxes}"
                                        LegendPosition="Bottom"
                                        HeightRequest="280"
                                        IsVisible="{Binding HasSnapshots}" />
                    <Label Text="{markup:Translate AssetTrendEmptyStateText}"
                           Style="{StaticResource CaptionStyle}"
                           HorizontalOptions="Center"
                           IsVisible="{Binding HasSnapshots, Converter={StaticResource InverseBoolConverter}}" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{markup:Translate AssetTrendHistorySectionTitle}" Style="{StaticResource SectionTitleStyle}" />
                    <CollectionView ItemsSource="{Binding Snapshots}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Style="{StaticResource CardFrameStyle}" Margin="0,4,0,10" Padding="14">
                                    <VerticalStackLayout Spacing="14">
                                        <Label Text="{Binding Date, StringFormat='{}{0:yyyy/MM/dd}'}"
                                               Style="{StaticResource SectionTitleStyle}" />
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                                            <Frame Style="{StaticResource InputContainerStyle}" Padding="12" HasShadow="False">
                                                <VerticalStackLayout Spacing="4">
                                                    <Label Text="{markup:Translate AssetTrendStockLabel}" Style="{StaticResource CaptionStyle}" />
                                                    <Label Text="{Binding Stock, StringFormat='{}{0:N0}'}"
                                                           FontAttributes="Bold"
                                                           FontSize="16" />
                                                </VerticalStackLayout>
                                            </Frame>
                                            <Frame Grid.Column="1" Style="{StaticResource InputContainerStyle}" Padding="12" HasShadow="False">
                                                <VerticalStackLayout Spacing="4">
                                                    <Label Text="{markup:Translate AssetTrendCashLabel}" Style="{StaticResource CaptionStyle}" />
                                                    <Label Text="{Binding Cash, StringFormat='{}{0:N0}'}"
                                                           FontAttributes="Bold"
                                                           FontSize="16" />
                                                </VerticalStackLayout>
                                            </Frame>
                                            <Frame Grid.Row="1" Style="{StaticResource InputContainerStyle}" Padding="12" HasShadow="False">
                                                <VerticalStackLayout Spacing="4">
                                                    <Label Text="{markup:Translate AssetTrendFirstTradeLabel}" Style="{StaticResource CaptionStyle}" />
                                                    <Label Text="{Binding FirstTrade, StringFormat='{}{0:N0}'}"
                                                           FontAttributes="Bold"
                                                           FontSize="16" />
                                                </VerticalStackLayout>
                                            </Frame>
                                            <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource InputContainerStyle}" Padding="12" HasShadow="False">
                                                <VerticalStackLayout Spacing="4">
                                                    <Label Text="{markup:Translate AssetTrendPropertyLabel}" Style="{StaticResource CaptionStyle}" />
                                                    <Label Text="{Binding Property, StringFormat='{}{0:N0}'}"
                                                           FontAttributes="Bold"
                                                           FontSize="16" />
                                                </VerticalStackLayout>
                                            </Frame>
                                        </Grid>
                                        <HorizontalStackLayout Spacing="10" Margin="0,4,0,0">
                                            <Button Text="{markup:Translate EditButtonText}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditSnapshotCommand}"
                                                    CommandParameter="{Binding .}" />
                                            <Button Text="{markup:Translate DeleteButtonText}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteSnapshotCommand}"
                                                    CommandParameter="{Binding .}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
