<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:markup="clr-namespace:AccountingApp.Markup"
             x:Class="AccountingApp.Views.SettingsPage"
             Title="設定">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,24" Spacing="2">
            <Label Text="設定" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,8" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{markup:Translate LanguageLabel}" Style="{StaticResource SectionTitleStyle}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="{markup:Translate LanguageTraditionalChinese}"
                                Command="{Binding SetTraditionalChineseCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Text="{markup:Translate LanguageEnglish}"
                                Command="{Binding SetEnglishCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="主幣別" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="此幣別會作為首頁與統計預設顯示。" Style="{StaticResource CaptionStyle}" />
                    <Frame Style="{StaticResource InputContainerStyle}">
                        <Picker ItemsSource="{Binding Currencies}"
                                SelectedItem="{Binding SelectedCurrency}"
                                Title="選擇主幣別" />
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="分類管理" Style="{StaticResource SectionTitleStyle}" />
                    <Button Text="管理分類" Command="{Binding ManageCategoriesCommand}" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="資料匯出" Style="{StaticResource SectionTitleStyle}" />
                    <Button Text="匯出 CSV" Command="{Binding ExportCsvCommand}" />
                    <Button Text="匯出 Excel" Command="{Binding ExportExcelCommand}" />
                    <Button Text="匯入 JSON 種子資料" Command="{Binding ImportJsonCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Text="從 URL 匯入 JSON" Command="{Binding ImportJsonFromUrlCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}" Margin="0,0,0,0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Google Drive 備份" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="{Binding SelectedGoogleDriveFolder, StringFormat='目前資料夾：{0}'}"
                           Style="{StaticResource CaptionStyle}" />
                    <Button Text="使用 personaccount_backup 資料夾"
                            Command="{Binding SelectGoogleDriveFolderCommand}"
                            IsEnabled="{Binding IsGoogleDriveIdle}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Text="立即備份至 Google Drive"
                            Command="{Binding BackupNowCommand}"
                            IsEnabled="{Binding IsGoogleDriveIdle}" />
                    <Button Text="從 Google Drive 還原"
                            Command="{Binding RestoreFromGoogleDriveCommand}"
                            IsEnabled="{Binding IsGoogleDriveIdle}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <ActivityIndicator IsRunning="{Binding IsGoogleDriveBusy}"
                                       IsVisible="{Binding IsGoogleDriveBusy}" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
