<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:markup="clr-namespace:AccountingApp.Markup"
             x:Class="AccountingApp.Views.CategoryReportTransactionDetailPage"
             Title="{markup:Translate CategoryReportTransactionDetailPageTitle}">
    <ScrollView>
        <VerticalStackLayout Padding="16,12,16,24" Spacing="12">
            <Label Text="{Binding CategoryName}"
                   Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding PeriodLabel}"
                           Style="{StaticResource CaptionStyle}" />
                    <Label Text="{markup:Translate CategoryReportTransactionDetailTotalLabel}"
                           Style="{StaticResource CaptionStyle}" />
                    <Label Text="{Binding TotalAmountText}"
                           FontAttributes="Bold"
                           FontSize="28"
                           TextColor="{StaticResource Danger}" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="{markup:Translate CategoryReportTransactionDetailEmptyStateText}"
                   Style="{StaticResource CaptionStyle}"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasTransactions, Converter={StaticResource InverseBoolConverter}}" />

            <CollectionView ItemsSource="{Binding TransactionGroups}"
                            IsGrouped="True"
                            IsVisible="{Binding HasTransactions}">
                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate>
                        <Label Text="{Binding DateLabel}"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,12,0,4" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource CardFrameStyle}"
                               Padding="12"
                               Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="4">
                                <Label Text="{Binding Note}"
                                       LineBreakMode="TailTruncation" />
                                <Label Grid.Column="1"
                                       Text="{Binding AmountText}"
                                       HorizontalTextAlignment="End" />
                                <Label Grid.Row="1"
                                       Text="{Binding CurrencyText}"
                                       Style="{StaticResource CaptionStyle}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
