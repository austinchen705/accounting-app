<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccountingApp.Views.BudgetPage"
             Title="預算管理">

    <CollectionView ItemsSource="{Binding BudgetItems}" Margin="16">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="0,4" Padding="12" CornerRadius="8">
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding CategoryName}"
                                   FontSize="16" FontAttributes="Bold" />
                            <Button Grid.Column="1" Text="設定"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetBudgetCommand}"
                                    CommandParameter="{Binding .}"
                                    FontSize="12" Padding="8,4" />
                        </Grid>
                        <Label Text="{Binding RatioText}" FontSize="12" TextColor="Gray" />
                        <ProgressBar Progress="{Binding Ratio}"
                                     ProgressColor="{Binding BarColor}" />
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
