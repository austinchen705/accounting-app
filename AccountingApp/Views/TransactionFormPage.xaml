<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AccountingApp.Views.Controls"
             xmlns:markup="clr-namespace:AccountingApp.Markup"
             x:Class="AccountingApp.Views.TransactionFormPage"
             Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,120" Spacing="14">
            <Label Text="{Binding PageTitle}" Style="{StaticResource PageTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{markup:Translate TransactionFormPrimarySectionTitle}" Style="{StaticResource SectionTitleStyle}" />

                    <Label Text="{markup:Translate TransactionFormTypeLabel}" Style="{StaticResource CaptionStyle}" />
                    <HorizontalStackLayout Spacing="16">
                        <RadioButton Content="{markup:Translate TransactionFormExpenseType}" Value="expense" IsChecked="{Binding Type, Converter={StaticResource StringEqualConverter}, ConverterParameter=expense}" />
                        <RadioButton Content="{markup:Translate TransactionFormIncomeType}" Value="income" IsChecked="{Binding Type, Converter={StaticResource StringEqualConverter}, ConverterParameter=income}" />
                    </HorizontalStackLayout>

                    <Label Text="{markup:Translate TransactionFormAmountLabel}" Style="{StaticResource CaptionStyle}" />
                    <Frame Style="{StaticResource InputContainerStyle}">
                        <Entry x:Name="AmountEntry"
                               Text="{Binding AmountText}"
                               Placeholder="0"
                               Keyboard="Numeric"
                               FontSize="28"
                               ReturnType="Next"
                               Completed="OnAmountEntryCompleted" />
                    </Frame>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                        <Label Text="{markup:Translate TransactionFormCategoryLabel}" Style="{StaticResource CaptionStyle}" />
                        <Label Grid.Column="1" Text="{markup:Translate TransactionFormDateLabel}" Style="{StaticResource CaptionStyle}" />
                        <Frame Grid.Row="1" Style="{StaticResource InputContainerStyle}">
                            <Picker ItemsSource="{Binding Categories}"
                                    SelectedItem="{Binding SelectedCategory}"
                                    ItemDisplayBinding="{Binding Name}" />
                        </Frame>
                        <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource InputContainerStyle}">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8"
                                  Padding="12,10">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference FormCalendarDatePicker}, Path=OpenCalendarCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="{Binding Source={x:Reference FormCalendarDatePicker}, Path=DateDisplayText}"
                                       VerticalOptions="Center"
                                       FontSize="16"
                                       FontAttributes="None"
                                       LineBreakMode="NoWrap"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
                                <Label Grid.Column="1"
                                       Text="⌄"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       FontSize="16"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}" />
                            </Grid>
                        </Frame>
                    </Grid>

                    <controls:CalendarDatePicker x:Name="FormCalendarDatePicker"
                                                 Date="{Binding Date}"
                                                 ShowTrigger="False" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{markup:Translate TransactionFormSecondarySectionTitle}" Style="{StaticResource SectionTitleStyle}" />

                    <Label Text="{markup:Translate TransactionFormNoteLabel}" Style="{StaticResource CaptionStyle}" />
                    <Frame Style="{StaticResource InputContainerStyle}">
                        <Entry x:Name="NoteEntry"
                               Text="{Binding Note}"
                               Placeholder="{markup:Translate TransactionFormNotePlaceholder}"
                               ReturnType="Done" />
                    </Frame>

                    <Label Text="{markup:Translate TransactionFormCurrencyLabel}" Style="{StaticResource CaptionStyle}" />
                    <Frame Style="{StaticResource InputContainerStyle}">
                        <Picker ItemsSource="{Binding Currencies}" SelectedItem="{Binding Currency}" />
                    </Frame>

                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Danger}"
                           IsVisible="{Binding HasError}" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="{Binding SaveButtonText}" Command="{Binding SaveCommand}" Margin="0,2,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
