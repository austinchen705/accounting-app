<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AccountingApp.Views.Controls"
             x:Class="AccountingApp.Views.TransactionFormPage"
             Title="新增記錄">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,120" Spacing="14">
            <Label Text="新增記錄" Style="{StaticResource PageTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="主要資訊" Style="{StaticResource SectionTitleStyle}" />

                    <Label Text="類型" Style="{StaticResource CaptionStyle}" />
                    <HorizontalStackLayout Spacing="16">
                        <RadioButton Content="支出" Value="expense" IsChecked="{Binding Type, Converter={StaticResource StringEqualConverter}, ConverterParameter=expense}" />
                        <RadioButton Content="收入" Value="income" IsChecked="{Binding Type, Converter={StaticResource StringEqualConverter}, ConverterParameter=income}" />
                    </HorizontalStackLayout>

                    <Label Text="金額" Style="{StaticResource CaptionStyle}" />
                    <Frame Style="{StaticResource InputContainerStyle}">
                        <Entry Text="{Binding Amount}" Placeholder="0" Keyboard="Numeric" FontSize="28" />
                    </Frame>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                        <Label Text="分類" Style="{StaticResource CaptionStyle}" />
                        <Label Grid.Column="1" Text="日期" Style="{StaticResource CaptionStyle}" />
                        <Frame Grid.Row="1" Style="{StaticResource InputContainerStyle}">
                            <Picker ItemsSource="{Binding Categories}"
                                    SelectedItem="{Binding SelectedCategory}"
                                    ItemDisplayBinding="{Binding Name}" />
                        </Frame>
                        <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource InputContainerStyle}">
                            <Button Text="{Binding Source={x:Reference FormCalendarDatePicker}, Path=DateDisplayText}"
                                    Command="{Binding Source={x:Reference FormCalendarDatePicker}, Path=OpenCalendarCommand}"
                                    HorizontalOptions="Fill"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
                        </Frame>
                    </Grid>

                    <controls:CalendarDatePicker x:Name="FormCalendarDatePicker"
                                                 Date="{Binding Date}"
                                                 ShowTrigger="False" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="補充資訊" Style="{StaticResource SectionTitleStyle}" />

                    <Label Text="備註" Style="{StaticResource CaptionStyle}" />
                    <Frame Style="{StaticResource InputContainerStyle}">
                        <Entry Text="{Binding Note}" Placeholder="選填" />
                    </Frame>

                    <Label Text="幣別" Style="{StaticResource CaptionStyle}" />
                    <Frame Style="{StaticResource InputContainerStyle}">
                        <Picker ItemsSource="{Binding Currencies}" SelectedItem="{Binding Currency}" />
                    </Frame>

                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Danger}"
                           IsVisible="{Binding HasError}" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="儲存記錄" Command="{Binding SaveCommand}" Margin="0,2,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
