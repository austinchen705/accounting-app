<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AccountingApp.Views.HomePage"
             Shell.NavBarIsVisible="False"
             Title="首頁">

    <Grid>
        <Grid RowDefinitions="Auto,*" Padding="16,6,16,8" RowSpacing="8">

            <Frame Grid.Row="0" Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <Button Text="‹"
                                Command="{Binding PreviousMonthCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                WidthRequest="40"
                                HeightRequest="36"
                                Padding="0" />
                        <Label Grid.Column="1"
                               Text="{Binding CurrentMonthLabel}"
                               Style="{StaticResource SectionTitleStyle}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                        <Button Grid.Column="2"
                                Text="›"
                                Command="{Binding NextMonthCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                WidthRequest="40"
                                HeightRequest="36"
                                Padding="0" />
                    </Grid>
                    <Label Text="{Binding SummaryTitle}" Style="{StaticResource CaptionStyle}" HorizontalOptions="Center" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                            <Label Text="收入" Style="{StaticResource CaptionStyle}" HorizontalOptions="Center" />
                            <Label Text="{Binding TotalIncome, StringFormat='{0:N0}'}"
                                   Style="{StaticResource ValueStyle}" TextColor="{StaticResource Success}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                            <Label Text="支出" Style="{StaticResource CaptionStyle}" HorizontalOptions="Center" />
                            <Label Text="{Binding TotalExpense, StringFormat='{0:N0}'}"
                                   Style="{StaticResource ValueStyle}" TextColor="{StaticResource Danger}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                            <Label Text="結餘" Style="{StaticResource CaptionStyle}" HorizontalOptions="Center" />
                            <Label Text="{Binding Balance, StringFormat='{0:N0}'}"
                                   Style="{StaticResource ValueStyle}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Grid Grid.Row="1">
                <Label Text="該月份尚無收支資料，點右下角新增第一筆。"
                       Style="{StaticResource CaptionStyle}"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"
                       IsVisible="{Binding HasRecentTransactions, Converter={StaticResource InverseBoolConverter}}" />

                <ScrollView IsVisible="{Binding HasRecentTransactions}">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="最近記錄" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecentTransactions}" Spacing="0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Frame Style="{StaticResource CardFrameStyle}" Padding="14,10" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="{Binding Date, StringFormat='{0:MM/dd ddd}'}"
                                                       Style="{StaticResource CaptionStyle}" />
                                                <Label Text="{Binding ExchangeInfoText}"
                                                       Style="{StaticResource CaptionStyle}"
                                                       IsVisible="{Binding HasExchangeInfo}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1"
                                                   Text="{Binding AmountDisplayText}"
                                                   Style="{StaticResource ValueStyle}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Grid>

        <Button Text="新增"
                Command="{Binding AddTransactionCommand}"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,28"
                Padding="20,12"
                CornerRadius="24"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White" />
    </Grid>

</ContentPage>
